# Atlassian Environment Variables

# Connection
ATLASSIAN_AGENT_URL=https://your-domain.atlassian.net

# Authentication (choose one method)
# Method 1: Basic Auth (email + API token) — Most common
ATLASSIAN_AGENT_USER=your-email@example.com
ATLASSIAN_AGENT_TOKEN=your-api-token

# Method 2: 3-Legged OAuth (3LO) — Bearer token from OAuth consent flow
# ATLASSIAN_OAUTH_TOKEN=

# Method 3: OIDC Delegation — RFC 8693 Token Exchange (enterprise SSO)
# ENABLE_DELEGATION=true
# AUDIENCE=https://your-domain.atlassian.net
# DELEGATED_SCOPES=read:jira-work write:jira-work

# SSL Verification
ATLASSIAN_AGENT_VERIFY=True

# Suite-specific overrides (optional — falls back to shared vars above)
# ATLASSIAN_JIRA_CLOUD_URL=
# ATLASSIAN_JIRA_CLOUD_USER=
# ATLASSIAN_JIRA_CLOUD_TOKEN=
# ATLASSIAN_CONFLUENCE_CLOUD_URL=
# ATLASSIAN_CONFLUENCE_CLOUD_USER=
# ATLASSIAN_CONFLUENCE_CLOUD_TOKEN=

# MCP Server Configuration
HOST=0.0.0.0
PORT=9607
TRANSPORT=stdio

# Debug
DEBUG=False
PYTHONUNBUFFERED=1
